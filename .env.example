# Copy this to .env and fill in values
DB_USERNAME=postgres
DB_PASSWORD=postgres
JWT_SECRET=your-256-bit-secret-change-this-in-production-must-be-long
JWT_EXPIRATION_MS=86400000

# Admin account — created/reconciled at startup from these values (source of truth).
# The app rewrites the admin password to ADMIN_PASSWORD on every boot, so this is
# how you set/rotate it. Keep the email matching your existing admin (admin@towin.com)
# to update that row instead of creating a second admin. Leave blank to skip bootstrap.
# ALWAYS set a strong ADMIN_PASSWORD in production.
ADMIN_EMAIL=admin@towin.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# "Ask AI" tortoise help assistant — free Groq API key (starts with gsk_).
# Get one at https://console.groq.com/keys. Server-side only; never exposed to
# the browser. Leave blank to disable the assistant. Set this in Railway for prod.
GROQ_API_KEY=
# Optional overrides (sensible defaults in application.yml):
# GROQ_MODEL=openai/gpt-oss-20b
# GROQ_ENABLED=true
