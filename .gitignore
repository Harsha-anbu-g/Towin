# Committed ignore list — generic boilerplate only.
# Machine-local, tooling, and personal working-file ignores live in
# .git/info/exclude, which stays on this computer and is never pushed.

# Maven
target/
*.class

# IDE
.idea/
*.iml
.vscode/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Env / secrets — never commit these
.env
*.local
client_secret_*.json
# Test secrets — never commit real values into test resource files

# Logs
*.log
logs/

# Node
node_modules/
dist/
build/
*.csv

# Stray images / diagrams dropped at the repo root
/*.png
/*.svg
/*.jpeg
/*.jpg
