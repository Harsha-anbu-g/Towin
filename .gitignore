!docs/screenshots/trust.png

# Stray screenshots / diagrams at repo root
/*.png
/*.svg
/*.jpeg
/*.jpg

# Google OAuth client secret files — never commit these
client_secret_*.json

# Local working files — kept out of the repo
/private/
# Regenerable dependency-graph export (the tracked copy lives in docs/architecture/)
docs/architecture/frontend-graph.pdf
.vercel
.gstack/

# Claude Code machine-local settings (permissions/hooks for this machine only)
.claude/settings.local.json

# Impeccable skill hook caches generated next to audited pages (tool output)
**/.impeccable/

# Design/AI tooling & internal build docs — kept local, not part of the public repo
