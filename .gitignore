graphify-out/
docs-generated/
# dependency-cruiser interactive report (regenerable via `npm run graph:report`);
# the small diagram snapshot (.mmd) is kept as a viewable, GitHub-renderable diagram.
docs/architecture/frontend-deps.html
# Offline API docs / OpenAPI spec — expose the full API surface, so kept local
# only (regenerate with docs/architecture/build-offline-api-docs.sh)
docs/architecture/towin-api-docs.html
docs/architecture/towin-openapi.json
docs/architecture/towin-openapi.yaml

# Archived local working files (dev screenshots, tool output) — kept local, never published
.artifacts/

# Local dev assets / reference images (not part of the app)
assets/

# Local-only working files (kept local, not published)
notes/
tasks/
memory/

# Dev/verification screenshots — only the curated README set is tracked
docs/screenshots/*
!docs/screenshots/Streak.png
!docs/screenshots/admin.png
